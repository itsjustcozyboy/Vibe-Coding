# Claude Code environment examples
# Use either direct API key OR custom gateway settings.

# Direct API key mode
# ANTHROPIC_API_KEY=your_api_key_here

# Custom gateway mode
ANTHROPIC_BASE_URL=https://claude.1000.school
ANTHROPIC_AUTH_TOKEN=replace_with_your_token

# ── Todo API ──────────────────────────────────────────────
PORT=3000
DATABASE_URL=postgresql://todo_user:todo_pass@localhost:5432/todos
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
